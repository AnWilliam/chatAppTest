# WebSocket signaling server URL (client-side, exposed to browser)
# Local: ws://localhost:3001
# Production: wss://your-signaling-server.up.railway.app
NEXT_PUBLIC_SIGNALING_URL=ws://localhost:3001

# WebSocket server port (server-side; Railway/Render use PORT automatically)
SIGNALING_PORT=3001

# Required in production — your live frontend URL (no trailing slash)
# FRONTEND_ORIGIN=https://your-domain.com
